{
    "id": "io.github.hanthor.decks",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "decks",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "python3-deps",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [ "--share=network" ]
            },
            "build-commands": [
                "pip3 install --prefix=${FLATPAK_DEST} --no-warn-script-location python-pptx odfpy"
            ],
            "comment": "Network build for the himachal pipeline; Flathub -> vendored wheels."
        },
        {
            "name": "decks",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
